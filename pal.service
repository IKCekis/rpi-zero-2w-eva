[Unit]
Description=EVA Pixel Pal OLED display
After=network.target ble_server.service
Requires=ble_server.service

[Service]
ExecStart=/usr/bin/python3 /home/ikcekis/pal/main.py --driver luma
WorkingDirectory=/home/ikcekis/pal
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
